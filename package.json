{
  "name": "trellis",
  "version": "0.1.0",
  "description": "Lightweight CLI for managing plans with dependencies",
  "type": "module",
  "bin": {
    "trellis": "./dist/trellis.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.lib.json",
    "build:prod": "node build.mjs --minify && tsc -p tsconfig.lib.json",
    "test": "vitest run",
    "dev": "vitest",
    "test:dist": "npm run build && vitest run tests/dist-integration.test.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.4",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
